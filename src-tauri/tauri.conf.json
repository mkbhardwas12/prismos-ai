{
  "productName": "PrismOS-AI",
  "version": "0.5.0",
  "identifier": "com.prismos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PrismOS-AI — Local AI Operating System",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; connect-src 'self' http://localhost:11434 http://127.0.0.1:11434; font-src 'self' data:; worker-src 'self' blob:"
    },
    "trayIcon": {
      "id": "prismos-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "PrismOS-AI — Local AI Operating System"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mkbhardwas12/prismos-ai/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
